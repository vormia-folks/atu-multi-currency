{
    "name": "vormia-folks/atu-multi-currency",
    "description": "ATU Multi Currency - A package for Laravel that provides multi currency support for your e-commerce website.",
    "keywords": ["laravel", "php", "a2commerce", "atu", "atu-multi-currency","vormia"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0 || ^13.0",
        "livewire/livewire": "^4.0",
        "vormiaphp/vormia": "^5.4"
    },
    "suggest": {
        "vormiaphp/ui-livewireflux-admin": "Matches the Flux admin shell used by the admin pages."
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2"
    },
    "autoload": {
        "psr-4": {
            "Vormia\\ATUMultiCurrency\\": "src/"
        },
        "exclude-from-classmap": [
            "src/stubs/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Vormia\\ATUMultiCurrency\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vormia\\ATUMultiCurrency\\ATUMultiCurrencyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
